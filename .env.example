# AIModelJudge — environment variables
# Copy to ~/.hermes-aimodeljudge/.env and fill in the keys

# ── DeepSeek API (primary provider) ──────────────────────────────────
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# ── Additional providers ─────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-your-anthropic-key-here

# ── Model Comparison ─────────────────────────────────────────────────
MODEL_COMPARE_MODELS=deepseek-chat,gpt-4o
MODEL_COMPARE_JUDGE_MODEL=deepseek-chat
MODEL_COMPARE_MODE=judge
MODEL_COMPARE_TIMEOUT=120
MODEL_COMPARE_TEMPERATURE=0.7
MODEL_COMPARE_MAX_TOKENS=2048
MODEL_COMPARE_JUDGE_MAX_TOKENS=4096
MODEL_COMPARE_API_KEYS={}
MODEL_COMPARE_BASE_URLS={}
MODEL_COMPARE_LOG_LEVEL=WARNING

# ── Web Server ───────────────────────────────────────────────────────
AMJ_WEB_HOST=127.0.0.1
AMJ_WEB_PORT=9651
AMJ_ENV=development                       # development | test | prod
AMJ_DOMAIN=example.com                    # Domain for TLS/nginx (prod only)
AMJ_ALLOW_PROD=false                      # Allow AMJ_ENV=prod on this host
AMJ_MESSAGES_URL=http://127.0.0.1:8084
AMJ_ROUTER_URL=http://127.0.0.1:9084
AMJ_API_KEY=your-api-key-here

# ── Hook Profile ─────────────────────────────────────────────────────
ECC_HOOK_PROFILE=standard

# ── Model State ──────────────────────────────────────────────────────
MODEL_STATE_FILE=

# ── Telegram Bot ─────────────────────────────────────────────────────
AMJ_TELEGRAM_TOKEN=                   # Bot token from @BotFather (not set = bot disabled)
AMJ_TELEGRAM_ALLOWED_USERS=           # Comma-separated user IDs

# ── Gemini API ───────────────────────────────────────────────────────
GEMINI_API_KEY=                       # Key from Google AI Studio (aistudio.google.com)
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# ── Secrets Vault ─────────────────────────────────────────────────────
AMJ_MASTER_KEY=                       # Vault master key (32 url-safe base64 bytes)
                                      # If not set — auto-generated at ~/.hermes-aimodeljudge/master.key
AMJ_VAULT_PATH=                       # Path to vault.db (default ~/.hermes-aimodeljudge/vault.db)

# ── Audit ─────────────────────────────────────────────────────────────
AMJ_AUDIT_SECRET=                     # HMAC secret for audit chain (auto-generated if not set)
